// TODO: We can potentially increase localSize to 16x16 on hardware with subgroup support.

#extension GL_KHR_shader_subgroup_arithmetic : enable
spec const uint32 SG_SHARED_SIZE = 16;

#include "common/sh.gsl"
#include "common/ibl.gsl"
#include "atmosphere/constants.h"

#ifdef GL_KHR_shader_subgroup_arithmetic
#define SH_SHARED_SIZE (SG_SHARED_SIZE * SH3_COUNT)
#else
#define SH_SHARED_SIZE (SH_WG_LOCAL_SIZE * SH3_COUNT)
#endif

localSize = 8, 8, 1;

uniform sampler2DArray skybox;

buffer restrict std430 ShCache
{
	volatile uint32 counter;
	float4 cache[];
} sh;

shared float3 shShared[SH_SHARED_SIZE];

void main()
{
	bool isThreadValid = all(lessThan(gl.globalInvocationID.xy, uint2(textureSize(skybox, 0).xy)));
#ifdef GL_KHR_shader_subgroup_arithmetic
	uint32 sharedIndex = gl.subgroupID * SH3_COUNT;
#else
	uint32 sharedIndex = gl.localInvocationIndex * SH3_COUNT;
#endif

	const float invDim = 1.0f / textureSize(skybox, 0).x;
	float2 st = coordsToST(gl.globalInvocationID.xy, invDim);
	float3 dir = stToDir(st, gl.globalInvocationID.z);
	float shb[SH3_COUNT]; computeSh3Basis(dir, shb);
	float3 color = texelFetch(skybox, int3(gl.globalInvocationID), 0).rgb;
	color *= calcSolidAngleFast(st, invDim);

	for (uint32 i = 0; i < SH3_COUNT; i++)
	{
		float3 shColor = isThreadValid ? color * shb[i] : float3(0.0f);
#ifdef GL_KHR_shader_subgroup_arithmetic
		float3 subgroupSum = subgroupAdd(shColor);
		if (subgroupElect())
			shShared[sharedIndex + i] = subgroupSum;
#else
		shShared[sharedIndex + i] = shColor;
#endif
	}
	barrier();

#ifndef GL_KHR_shader_subgroup_arithmetic
	for (uint32 stride = (SH_WG_LOCAL_SIZE >> 1); stride > 0; stride >>= 1)
	{
		if (gl.localInvocationIndex < stride)
		{
			uint32 srcIndex = (gl.localInvocationIndex + stride) * SH3_COUNT;
			for (uint32 i = 0; i < SH3_COUNT; i++)
				shShared[sharedIndex + i] += shShared[srcIndex + i];
		}
		barrier();
	}
#endif

	if (gl.localInvocationIndex == 0)
	{
		uint32 index = atomicAdd(sh.counter, 1u) * SH3_COUNT;
		for (uint32 i = 0; i < SH3_COUNT; i++)
		{
			float3 shSum = shShared[i];
#ifdef GL_KHR_shader_subgroup_arithmetic
			for (uint32 j = 1; j < SG_SHARED_SIZE; j++)
				shSum += shShared[j * SH3_COUNT + i];
#endif
			sh.cache[index + i] = float4(shSum, 0.0f);
		}
	}
}